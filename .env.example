# =============================================================================
# Environment variables for qr-id-login-supabase
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# =============================================================================

# ---- Server ----------------------------------------------------------------
# Port the server listens on. Render/most hosts set this automatically.
PORT=3000

# Public URL of the deployed app, WITHOUT a trailing slash.
# Used to build the QR upload links the phone scans.
# Locally with a tunnel: e.g. https://abc123.ngrok-free.app
# On Render: e.g. https://your-app.onrender.com
# If left blank, the server guesses from the incoming request headers.
PUBLIC_BASE_URL=

# ---- Supabase (REQUIRED) ----------------------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service role key (SECRET - server only, bypasses RLS). Found in
# Supabase Dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Anon/public key. Present for completeness but NOT used by the current code.
SUPABASE_ANON_KEY=

# Storage bucket name. Must match the bucket created in Supabase.
SUPABASE_BUCKET=uploads

# ---- Sessions (REQUIRED) ----------------------------------------------------
# Long random string used to sign the login cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ---- Google Gemini AI chat --------------------------------------------------
# Required only if you want the AI chat feature to work.
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional overrides (otherwise read from config.json -> aiChat):
# GOOGLE_CHAT_MODEL=gemini-3-flash-preview
# CHAT_MAX_OUTPUT_CHARS=2000
